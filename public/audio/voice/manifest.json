      "file": "audio/voice/starfield/5m01.mp3",
      "ok": true,
      "duration": 4.39
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 2,
      "t": 45,
      "text": "注意你的呼吸。不需要改变它，只是看着它。",
      "file": "audio/voice/starfield/5m02.mp3",
      "ok": true,
      "duration": 4.3
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 3,
      "t": 90,
      "text": "想象你坐在高原上。夜空很低，银河就横在头顶。",
      "file": "audio/voice/starfield/5m03.mp3",
      "ok": true,
      "duration": 5.11
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 4,
      "t": 150,
      "text": "吸气时，星光落进身体；呼气时，身体亮一点，再亮一点。",
      "file": "audio/voice/starfield/5m04.mp3",
      "ok": true,
      "duration": 6.17
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 5,
      "t": 210,
      "text": "你比想象中辽阔。心里能装下的，不止这一片星空。",
      "file": "audio/voice/starfield/5m05.mp3",
      "ok": true,
      "duration": 5.11
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 6,
      "t": 270,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/starfield/5m06.mp3",
      "ok": true,
      "duration": 4.15
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 7,
      "t": 292,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/starfield/5m07.mp3",
      "ok": true,
      "duration": 2.47
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/starfield/10m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 1,
      "t": 25,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/starfield/10m01.mp3",
      "ok": true,
      "duration": 4.73
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 2,
      "t": 60,
      "text": "从头到脚，慢慢放松。额头、肩膀、手心，都松下来。",
      "file": "audio/voice/starfield/10m02.mp3",
      "ok": true,
      "duration": 6.5
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 3,
      "t": 100,
      "text": "注意你的呼吸。不需要改变它，只是看着它。",
      "file": "audio/voice/starfield/10m03.mp3",
      "ok": true,
      "duration": 4.27
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 4,
      "t": 160,
      "text": "吸气时，知道自己在吸气；呼气时，知道自己在呼气。",
      "file": "audio/voice/starfield/10m04.mp3",
      "ok": true,
      "duration": 4.99
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 5,
      "t": 230,
      "text": "想象你坐在高原上。夜空很低，星星一颗一颗，就在眼前。",
      "file": "audio/voice/starfield/10m05.mp3",
      "ok": true,
      "duration": 6.0
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 6,
      "t": 300,
      "text": "从脚尖到头顶，身体的每一个角落，都像一颗安静的星。",
      "file": "audio/voice/starfield/10m06.mp3",
      "ok": true,
      "duration": 5.42
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 7,
      "t": 370,
      "text": "吸气时，星光落进身体；呼气时，身体亮一点，再亮一点。",
      "file": "audio/voice/starfield/10m07.mp3",
      "ok": true,
      "duration": 6.17
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 8,
      "t": 440,
      "text": "偶尔走神，就像流星划过。看见了，就让它过去。",
      "file": "audio/voice/starfield/10m08.mp3",
      "ok": true,
      "duration": 4.97
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 9,
      "t": 510,
      "text": "你比想象中辽阔。心里能装下的，不止这一片星空。",
      "file": "audio/voice/starfield/10m09.mp3",
      "ok": true,
      "duration": 5.11
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 10,
      "t": 560,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/starfield/10m10.mp3",
      "ok": true,
      "duration": 4.15
    },
    {
      "hillId": "starfield",
      "minutes": 10,
      "index": 11,
      "t": 592,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/starfield/10m11.mp3",
      "ok": true,
      "duration": 2.47
    },
    {
      "hillId": "desert",
      "minutes": 5,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/desert/5m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "desert",
      "minutes": 5,
      "index": 1,
      "t": 20,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/desert/5m01.mp3",
      "ok": true,
      "duration": 4.39
    },
    {
      "hillId": "desert",
      "minutes": 5,
      "index": 2,
      "t": 45,
      "text": "注意你的呼吸。不需要改变它，只是看着它。",
      "file": "audio/voice/desert/5m02.mp3",
