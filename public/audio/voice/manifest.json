{
  "voiceId": "05Cdh2gw2NMzDvykn1nm",
  "entries": [
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/bamboo/5m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 1,
      "t": 20,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/bamboo/5m01.mp3",
      "ok": true,
      "duration": 4.39
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 2,
      "t": 45,
      "text": "注意你的呼吸。不需要改变它，只是看着它。",
      "file": "audio/voice/bamboo/5m02.mp3",
      "ok": true,
      "duration": 4.3
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 3,
      "t": 90,
      "text": "吸气时，知道自己在吸气；呼气时，知道自己在呼气。",
      "file": "audio/voice/bamboo/5m03.mp3",
      "ok": true,
      "duration": 5.71
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 4,
      "t": 150,
      "text": "如果走神了，没关系。发现走神的那一刻，就是回来的一刻。",
      "file": "audio/voice/bamboo/5m04.mp3",
      "ok": true,
      "duration": 5.33
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 5,
      "t": 210,
      "text": "想象风穿过竹林，念头也像风一样，来了，又会走。",
      "file": "audio/voice/bamboo/5m05.mp3",
      "ok": true,
      "duration": 5.16
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 6,
      "t": 270,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/bamboo/5m06.mp3",
      "ok": true,
      "duration": 4.15
    },
    {
      "hillId": "bamboo",
      "minutes": 5,
      "index": 7,
      "t": 295,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/bamboo/5m07.mp3",
      "ok": true,
      "duration": 3.19
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/bamboo/10m00.mp3",
      "ok": true,
      "duration": 3.82
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 1,
      "t": 25,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/bamboo/10m01.mp3",
      "ok": true,
      "duration": 4.78
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 2,
      "t": 60,
      "text": "从头到脚，慢慢放松。额头、肩膀、手心，都松下来。",
      "file": "audio/voice/bamboo/10m02.mp3",
      "ok": true,
      "duration": 6.46
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 3,
      "t": 100,
      "text": "注意你的呼吸。不需要改变它，只是看着它。",
      "file": "audio/voice/bamboo/10m03.mp3",
      "ok": true,
      "duration": 4.3
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 4,
      "t": 160,
      "text": "吸气时，知道自己在吸气；呼气时，知道自己在呼气。",
      "file": "audio/voice/bamboo/10m04.mp3",
      "ok": true,
      "duration": 5.3
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 5,
      "t": 230,
      "text": "给呼吸数个数。吸气，一；呼气，二。数到十，再从一开始。",
      "file": "audio/voice/bamboo/10m05.mp3",
      "ok": true,
      "duration": 8.4
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 6,
      "t": 300,
      "text": "如果走神了，没关系。发现走神的那一刻，就是回来的一刻。",
      "file": "audio/voice/bamboo/10m06.mp3",
      "ok": true,
      "duration": 5.28
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 7,
      "t": 370,
      "text": "想象风穿过竹林，念头也像风一样，来了，又会走。",
      "file": "audio/voice/bamboo/10m07.mp3",
      "ok": true,
      "duration": 5.16
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 8,
      "t": 440,
      "text": "回到身体。听一听周围的声音，远的，近的，都只是声音。",
      "file": "audio/voice/bamboo/10m08.mp3",
      "ok": true,
      "duration": 6.53
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 9,
      "t": 510,
      "text": "感受此刻的安静，像竹根扎进土里，稳稳的。",
      "file": "audio/voice/bamboo/10m09.mp3",
      "ok": true,
      "duration": 4.3
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 10,
      "t": 560,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/bamboo/10m10.mp3",
      "ok": true,
      "duration": 4.2
    },
    {
      "hillId": "bamboo",
      "minutes": 10,
      "index": 11,
      "t": 592,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/bamboo/10m11.mp3",
      "ok": true,
      "duration": 3.19
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/snowpeak/5m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 1,
      "t": 20,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/snowpeak/5m01.mp3",
      "ok": true,
      "duration": 4.37
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 2,
      "t": 45,
      "text": "注意你的呼吸。轻一点，像雪落在雪上。",
      "file": "audio/voice/snowpeak/5m02.mp3",
      "ok": true,
      "duration": 4.3
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 3,
      "t": 90,
      "text": "吸气时，知道自己在吸气；呼气时，知道自己在呼气。",
      "file": "audio/voice/snowpeak/5m03.mp3",
      "ok": true,
      "duration": 5.18
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 4,
      "t": 150,
      "text": "念头来了，把它想成一片雪。落在地上，就化了。",
      "file": "audio/voice/snowpeak/5m04.mp3",
      "ok": true,
      "duration": 4.58
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 5,
      "t": 210,
      "text": "你坐在云海之上。白茫茫的一片，什么都不用拿。",
      "file": "audio/voice/snowpeak/5m05.mp3",
      "ok": true,
      "duration": 4.54
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 6,
      "t": 270,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/snowpeak/5m06.mp3",
      "ok": true,
      "duration": 4.2
    },
    {
      "hillId": "snowpeak",
      "minutes": 5,
      "index": 7,
      "t": 292,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/snowpeak/5m07.mp3",
      "ok": true,
      "duration": 2.47
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/snowpeak/10m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 1,
      "t": 25,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/snowpeak/10m01.mp3",
      "ok": true,
      "duration": 4.78
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 2,
      "t": 60,
      "text": "从头到脚，慢慢放松。额头、肩膀、手心，都松下来。",
      "file": "audio/voice/snowpeak/10m02.mp3",
      "ok": true,
      "duration": 7.44
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 3,
      "t": 100,
      "text": "注意你的呼吸。轻一点，像雪落在雪上。",
      "file": "audio/voice/snowpeak/10m03.mp3",
      "ok": true,
      "duration": 4.25
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 4,
      "t": 160,
      "text": "吸气时，知道自己在吸气；呼气时，知道自己在呼气。",
      "file": "audio/voice/snowpeak/10m04.mp3",
      "ok": true,
      "duration": 5.74
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 5,
      "t": 230,
      "text": "杂念像雪片，一片一片，从很高的地方落下来。",
      "file": "audio/voice/snowpeak/10m05.mp3",
      "ok": true,
      "duration": 4.73
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 6,
      "t": 300,
      "text": "不用去扫雪。看着它落，落到地上，就安静了。",
      "file": "audio/voice/snowpeak/10m06.mp3",
      "ok": true,
      "duration": 4.58
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 7,
      "t": 370,
      "text": "想象你坐在白雪顶上，四周是云海，白得没有边。",
      "file": "audio/voice/snowpeak/10m07.mp3",
      "ok": true,
      "duration": 4.97
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 8,
      "t": 440,
      "text": "没有什么要拿起的，也没有什么要放下的。只是坐着。",
      "file": "audio/voice/snowpeak/10m08.mp3",
      "ok": true,
      "duration": 4.15
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 9,
      "t": 510,
      "text": "感受此刻的安静，像大雪之后，世界的无声。",
      "file": "audio/voice/snowpeak/10m09.mp3",
      "ok": true,
      "duration": 4.37
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 10,
      "t": 560,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/snowpeak/10m10.mp3",
      "ok": true,
      "duration": 4.22
    },
    {
      "hillId": "snowpeak",
      "minutes": 10,
      "index": 11,
      "t": 592,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/snowpeak/10m11.mp3",
      "ok": true,
      "duration": 3.1
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/lakeside/5m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 1,
      "t": 20,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/lakeside/5m01.mp3",
      "ok": true,
      "duration": 4.78
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 2,
      "t": 45,
      "text": "注意你的呼吸。像湖水一样，一起，一伏。",
      "file": "audio/voice/lakeside/5m02.mp3",
      "ok": true,
      "duration": 4.92
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 3,
      "t": 90,
      "text": "想象你的心是一片湖面，呼吸是吹过湖面的风。",
      "file": "audio/voice/lakeside/5m03.mp3",
      "ok": true,
      "duration": 5.21
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 4,
      "t": 150,
      "text": "情绪来了，像一圈涟漪。看着它升起，看着它散开。",
      "file": "audio/voice/lakeside/5m04.mp3",
      "ok": true,
      "duration": 6.14
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 5,
      "t": 210,
      "text": "波纹会平，湖面会静。你不需要做什么，水知道答案。",
      "file": "audio/voice/lakeside/5m05.mp3",
      "ok": true,
      "duration": 5.95
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 6,
      "t": 270,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/lakeside/5m06.mp3",
      "ok": true,
      "duration": 4.25
    },
    {
      "hillId": "lakeside",
      "minutes": 5,
      "index": 7,
      "t": 292,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/lakeside/5m07.mp3",
      "ok": true,
      "duration": 2.47
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
      "file": "audio/voice/lakeside/10m00.mp3",
      "ok": true,
      "duration": 3.86
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 1,
      "t": 25,
      "text": "感受身体和座位接触的地方，让重量慢慢沉下去。",
      "file": "audio/voice/lakeside/10m01.mp3",
      "ok": true,
      "duration": 4.61
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 2,
      "t": 60,
      "text": "从头到脚，慢慢放松。额头、肩膀、手心，都松下来。",
      "file": "audio/voice/lakeside/10m02.mp3",
      "ok": true,
      "duration": 6.41
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 3,
      "t": 100,
      "text": "注意你的呼吸。像湖水一样，一起，一伏。",
      "file": "audio/voice/lakeside/10m03.mp3",
      "ok": true,
      "duration": 4.92
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 4,
      "t": 160,
      "text": "吸气时，知道自己在吸气；呼气时，知道自己在呼气。",
      "file": "audio/voice/lakeside/10m04.mp3",
      "ok": true,
      "duration": 5.88
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 5,
      "t": 230,
      "text": "想象你的心是一片湖面。很宽，很安静，倒映着天光。",
      "file": "audio/voice/lakeside/10m05.mp3",
      "ok": true,
      "duration": 6.07
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 6,
      "t": 300,
      "text": "情绪来了，像一圈涟漪。不推开它，也不跟着它走。",
      "file": "audio/voice/lakeside/10m06.mp3",
      "ok": true,
      "duration": 4.82
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 7,
      "t": 370,
      "text": "看着它升起，看着它一圈一圈，慢慢散开。",
      "file": "audio/voice/lakeside/10m07.mp3",
      "ok": true,
      "duration": 4.58
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 8,
      "t": 440,
      "text": "浪会退，波纹会平。湖水从不动摇，它只是照见。",
      "file": "audio/voice/lakeside/10m08.mp3",
      "ok": true,
      "duration": 5.98
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 9,
      "t": 510,
      "text": "感受此刻的安静，像深夜的湖，平得照见星星。",
      "file": "audio/voice/lakeside/10m09.mp3",
      "ok": true,
      "duration": 4.49
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 10,
      "t": 560,
      "text": "最后一次深呼吸。吸气……呼气……",
      "file": "audio/voice/lakeside/10m10.mp3",
      "ok": true,
      "duration": 4.15
    },
    {
      "hillId": "lakeside",
      "minutes": 10,
      "index": 11,
      "t": 592,
      "text": "准备好了，就慢慢睁开眼睛。",
      "file": "audio/voice/lakeside/10m11.mp3",
      "ok": true,
      "duration": 3.19
    },
    {
      "hillId": "starfield",
      "minutes": 5,
      "index": 0,
      "t": 0,
      "text": "找一个舒服的姿势坐好，轻轻闭上眼睛。",
